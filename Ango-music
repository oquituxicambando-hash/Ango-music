<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ANGO MUSIC - Login</title>
<style>
/* RESET E BODY */
html, body {
    width: 100%;
    height: 100%;
    margin: 0;
    font-family: Arial, sans-serif;
    background: green; /* Fundo verde */
    display: flex;
    justify-content: center; /* centro horizontal */
    align-items: center;     /* centro vertical */
}

/* CAIXA DE LOGIN */
.login {
    background: white;
    padding: 30px 25px;
    width: 320px;
    text-align: center;
    border-radius: 12px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.3);
}

/* NOME DO SITE */
.login .site-name {
    font-size: 26px;
    font-weight: bold;
    margin-bottom: 15px;
    color: #000; /* visível */
}

/* SUBTÍTULO */
.login h2 {
    margin-bottom: 20px;
    font-size: 16px;
    color: #333;
}

/* INPUTS */
.login input {
    width: 100%;
    padding: 12px;
    margin: 8px 0;
    border: 1px solid #ccc;
    border-radius: 8px;
    font-size: 14px;
}

/* BOTÃO */
.login button {
    width: 100%;
    padding: 12px;
    background: green;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: bold;
    cursor: pointer;
    margin-top: 10px;
    transition: 0.3s;
}

.login button:hover {
    opacity: 0.9;
    transform: translateY(-1px);
}

/* LINKS */
.links {
    margin-top: 15px;
    display: flex;
    justify-content: space-between;
}

.links a {
    font-size: 12px;
    color: green;
    text-decoration: none;
}

.links a:hover {
    text-decoration: underline;
}
</style>
</head>
<body>

<div class="login">
    <div class="site-name">ANGO MUSIC</div>
    <h2>Faz login ou cria a tua conta</h2>
    <form id="loginForm">
        <input type="email" id="email" placeholder="Email (Google)" required>
        <input type="password" id="senha" placeholder="Senha" required>
        <button type="submit">Entrar</button>
    </form>
    <div class="links">
        <a href="#">Criar conta</a>
        <a href="#">Esqueci a senha</a>
    </div>
</div>

<script>
// JAVASCRIPT: VALIDAÇÃO E LOGIN SIMPLES
document.getElementById("loginForm").addEventListener("submit", function(e){
    e.preventDefault(); // impede refresh da página

    const email = document.getElementById("email").value.trim();
    const senha = document.getElementById("senha").value.trim();

    // validação simples
    if(email.includes("@") && senha.length >= 6){
        alert("Login bem-sucedido! 👌");
        // FUTURO: redirecionar para a página principal do site
        // window.location.href = "home.html";
    } else {
        alert("Email ou senha inválidos 😔");
    }
});
</script>

</body>
</html>
